# Copy to .env and fill in values:  cp .env.example .env

# Server
PORT=3000
NODE_ENV=production

# API authentication – set a strong secret; clients send X-Api-Key or Authorization: Bearer
API_KEY=your-secret-api-key-here

# CORS (optional – e.g. * or https://your-app.com)
# CORS_ORIGIN=

# Rate limits (requests per minute per IP)
# RATE_LIMIT_MAX=120
# WATCH_RATE_LIMIT_MAX=30

# Cache TTL in seconds (8 hours)
CACHE_TTL=28800

# Watch endpoint cache TTL in seconds (3 minutes)
# WATCH_CACHE_TTL=180

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000
# Retry count for temporary upstream blocks (403/429/5xx)
# REQUEST_RETRY_COUNT=2

# Optional outbound scrape fingerprint overrides (helpful on VPS/datacenter IPs)
# SCRAPE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36
# SCRAPE_COOKIE=

# Comma-separated allowed scrape hostnames (defaults to xvideos domains)
# ALLOWED_SCRAPE_HOSTS=www.xvideos.com,xvideos.com

# Website 1 – Home
HOME_BASE_URL=https://www.example.com
HOME_LIST_PATH=/best/2026-05

# Website 2 – Models
MODELS_BASE_URL=https://www.example.com
MODELS_LIST_PATH=/pornstars-index

# Website 3 – Tags
TAGS_BASE_URL=https://www.example.com
TAGS_LIST_PATH=/tags

# Website 4 – Channels
CHANNELS_BASE_URL=https://www.example.com
CHANNELS_LIST_PATH=/channels-index

# Watch (uses video page URL from client – base used for referer only)
WATCH_BASE_URL=https://www.example.com
WATCH_REFERER=https://www.example.com/
