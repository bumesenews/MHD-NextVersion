{
  "name": "scraper-api",
  "version": "1.0.0",
  "description": "Production-ready configuration-driven scraping API for Flutter apps",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop scraper-api",
    "pm2:restart": "pm2 restart scraper-api",
    "pm2:logs": "pm2 logs scraper-api"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "node-cache": "^5.1.2"
  }
}
